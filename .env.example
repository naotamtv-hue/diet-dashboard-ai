# ===== diet-dashboard-ai 環境変数テンプレート =====
# 本番デプロイ時はホスティングの環境変数設定にこれらを登録する。

# 実行環境
NODE_ENV=production
PORT=3000

# データベース
# ローカル: file:local.db
# 本番(Turso等のリモートlibsql): libsql://<db-name>-<org>.turso.io
DATABASE_URL=file:local.db
# リモートDBのみ必要(Tursoの認証トークン)。ローカルfile:では空でOK。
DATABASE_AUTH_TOKEN=

# セッションJWT署名鍵(十分長いランダム文字列)
JWT_SECRET=

# AI (Google Gemini の OpenAI 互換エンドポイント)
BUILT_IN_FORGE_API_URL=https://generativelanguage.googleapis.com/v1beta/openai
BUILT_IN_FORGE_API_KEY=
AI_MODEL=gemini-2.5-flash

# ↓ Manus(旧基盤)残骸。自前認証へ移行済みのため本番では未使用/任意。
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
